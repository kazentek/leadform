{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/embed.js",
      "dest": "/public/embed.js",
      "headers": {
        "Cache-Control": "public, max-age=300, s-maxage=300",
        "Access-Control-Allow-Origin": "*",
        "Content-Type": "application/javascript; charset=utf-8"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "SHOP_DOMAIN": "@shop_domain",
    "SHOP_TOKEN": "@shop_token"
  }
}
